#!/usr/bin/env bash

# md2html - convert a markdown file (with mermaid support) to a single HTML file
# Requires: pandoc
#
# Usage:
#   md2html file.md          - convert file, output HTML to stdout
#   cat file.md | md2html    - read from stdin, output HTML to stdout

set -euo pipefail

# Create temporary files
mermaid_filter=$(mktemp --suffix=.lua)
toc_template=$(mktemp --suffix=.html)
trap 'rm -f "$mermaid_filter" "$toc_template"' EXIT

echo '$toc$' > "$toc_template"

cat > "$mermaid_filter" <<'FILTER'
function CodeBlock(block)
  if block.classes[1] == "mermaid" then
    local text = block.text
    -- Strip YAML frontmatter (everything between --- and ---) from start of block
    text = text:gsub("^%-%-%-.-%-%-%-\n", "")
    return pandoc.RawBlock("html", "<pre class=\"mermaid\">\n" .. text .. "\n</pre>")
  end
end
FILTER

# Read input: file argument or stdin
if [ $# -ge 1 ] && [ -f "$1" ]; then
	input_file="$1"
	md_content=$(cat "$input_file")
else
	md_content=$(cat)
fi

# Embed font as base64 data URI — file:// refs are blocked when the HTML is served over http://
# Only the regular weight is embedded; the browser synthesizes bold.
font_regular="$HOME/.local/share/fonts/Go/Go-Mono.ttf"
font_regular_src='local("Go Mono")'
if [ -f "$font_regular" ]; then
	font_regular_src="url(\"data:font/ttf;base64,$(base64 -w0 "$font_regular")\") format(\"truetype\")"
fi

# Generate TOC
toc_html=$(echo "$md_content" | pandoc -f markdown+fenced_code_attributes+lists_without_preceding_blankline -t html --toc --template="$toc_template" 2>/dev/null)

# Convert markdown to HTML fragment
body_html=$(echo "$md_content" | pandoc -f markdown+fenced_code_attributes+lists_without_preceding_blankline -t html --highlight-style=kate --lua-filter "$mermaid_filter" 2>/dev/null)

# Only render the ToC aside (and enable the sidebar grid layout) when there's something to show.
if printf '%s' "$toc_html" | grep -q '<a '; then
	toc_aside="<aside class=\"toc-wrap\"><nav id=\"toc\">${toc_html}</nav></aside>"
	body_class=' class="has-toc"'
else
	toc_aside=""
	body_class=""
fi

cat <<HTMLEOF
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>md2html</title>
<script type="module">
  try {
    const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
    mermaid.initialize({ startOnLoad: true, securityLevel: 'loose', theme: 'base' });
  } catch (e) {
    console.warn('Mermaid failed:', e);
  }
</script>
<style>
@font-face {
  font-family: "Go Mono";
  src: $font_regular_src;
  font-weight: normal;
  font-style: normal;
}
:root {
  --bg: #fff; --fg: #222; --muted: #666; --border: #ccc; --accent: #444;
  --code-bg: #ececec;
}
@media (prefers-color-scheme: dark) {
  :root { --bg: #1a1a1a; --fg: #e0e0e0; --muted: #888; --border: #444; --accent: #aaa; --code-bg: #2a2a2a; }
}
* { box-sizing: border-box; }
body {
  font-family: "Noto Serif", Georgia, "Times New Roman", serif;
  font-size: 1.15rem;
  margin: 0;
  padding: 2rem 1rem;
  background: var(--bg);
  color: var(--fg);
  line-height: 1.5;
}
main { max-width: 70ch; margin: 0 auto; min-width: 0; }
:is(h1, h2, h3, h4, h5, h6)[id] { scroll-margin-top: 1rem; }
a { color: var(--accent); }
code, pre { font-family: "Go Mono", monospace; }
blockquote {
  margin: 1rem 0;
  padding: 0.5rem 1rem;
  border-left: 3px solid var(--muted);
  color: var(--muted);
  font-style: italic;
}
blockquote > *:first-child { margin-top: 0; }
blockquote > *:last-child { margin-bottom: 0; }
pre { overflow-x: auto; padding: 0.5rem; }
code {
  font-size: 0.9em;
  background: color-mix(in srgb, var(--border) 35%, transparent);
  padding: 0.1em 0.3em;
  border-radius: 3px;
}
pre code { background: none; padding: 0; border-radius: 0; }
img { max-width: 100%; }
pre.mermaid {
  background: transparent;
  width: min(1500px, calc(100vw - 4rem));
  margin-left: calc(50% - min(750px, 50vw - 2rem));
}
pre.mermaid svg {
  width: 100%;
  height: auto;
}
@media (max-width: 1599px) {
  pre.mermaid { overflow-x: auto; }
}
/* Pandoc syntax highlighting (monochrome) */
pre > code.sourceCode { white-space: pre; position: relative; }
pre > code.sourceCode > span { line-height: 1.25; }
pre > code.sourceCode > span:empty { height: 1.2em; }
code.sourceCode > span { color: inherit; text-decoration: inherit; }
div.sourceCode { margin: 1em 0; background: var(--code-bg); border: 1px solid var(--border); }
pre.sourceCode { margin: 0; }
@media screen { div.sourceCode { overflow: auto; } }
code span.al { font-weight: bold; }
code span.an { font-style: italic; }
code span.cf { font-weight: bold; }
code span.co { font-style: italic; }
code span.cv { font-style: italic; }
code span.do { font-style: italic; }
code span.dt { text-decoration: underline; }
code span.er { font-weight: bold; }
code span.in { font-style: italic; }
code span.kw { font-weight: bold; }
code span.pp { font-weight: bold; }
code span.wa { font-style: italic; }
aside.toc-wrap { min-width: 0; }
nav#toc {
  margin: 0 auto 2rem;
  padding: 1rem;
  border: 1px solid var(--border);
  max-width: 70ch;
  font-size: 0.95rem;
}
nav#toc > ul { margin: 0; padding-left: 1.2em; }
nav#toc ul { list-style: none; padding-left: 1em; }
nav#toc li { margin: 0.2em 0; }
nav#toc a {
  display: inline-block;
  text-decoration: none;
  line-height: 1.3;
  overflow-wrap: anywhere;
  border-left: 2px solid transparent;
  padding-left: 0.4em;
  margin-left: -0.4em;
}
nav#toc a.active {
  font-weight: bold;
  color: var(--fg);
  border-left-color: var(--accent);
}

/* Sidebar layout: only when a ToC exists AND viewport is wide enough.
   Two-column grid centered in the viewport so wide monitors don't get stretched. */
@media (min-width: 70rem) {
  body.has-toc {
    display: grid;
    grid-template-columns: minmax(0, 18rem) minmax(0, 70ch);
    column-gap: 2rem;
    justify-content: center;
  }
  body.has-toc aside.toc-wrap { grid-column: 1; min-width: 0; }
  body.has-toc main { grid-column: 2; margin: 0; max-width: none; }
  body.has-toc nav#toc {
    position: sticky;
    top: 1rem;
    margin: 0;
    max-width: none;
    max-height: calc(100vh - 2rem);
    overflow-y: auto;
  }
}
table {
  border-collapse: collapse;
  margin: 1rem 0;
  display: block;
  max-width: 100%;
  overflow-x: auto;
}
th, td {
  border: 1px solid var(--border);
  padding: 0.4rem 0.6rem;
  vertical-align: top;
  text-align: left;
}
th { background: var(--border); }
tbody tr:nth-child(even) td { background: color-mix(in srgb, var(--border) 25%, transparent); }
</style>
</head>
<body${body_class}>
${toc_aside}
<main>
$body_html
</main>
<script>
(function () {
  const tocLinks = document.querySelectorAll('nav#toc a[href^="#"]');
  if (!tocLinks.length) return;
  const linkById = new Map();
  tocLinks.forEach(a => {
    try {
      const id = decodeURIComponent(a.getAttribute('href').slice(1));
      if (id) linkById.set(id, a);
    } catch (_) {}
  });
  const targets = [];
  linkById.forEach((_, id) => {
    const el = document.getElementById(id);
    if (el) targets.push(el);
  });
  if (!targets.length) return;

  // Normalize to document order so we can short-circuit the scan.
  targets.sort((a, b) =>
    (a.compareDocumentPosition(b) & Node.DOCUMENT_POSITION_FOLLOWING) ? -1 : 1);

  const toc = document.querySelector('nav#toc');
  // Scroll only inside the ToC's own overflow box — never the page.
  // In stacked (narrow) mode the nav has no internal scroll, so we no-op.
  const keepLinkVisibleInToc = (link) => {
    if (!toc || toc.scrollHeight <= toc.clientHeight) return;
    const lr = link.getBoundingClientRect();
    const tr = toc.getBoundingClientRect();
    if (lr.top < tr.top) toc.scrollTop += lr.top - tr.top - 4;
    else if (lr.bottom > tr.bottom) toc.scrollTop += lr.bottom - tr.bottom + 4;
  };

  let active = null;
  const update = () => {
    const line = Math.max(80, window.innerHeight * 0.25);
    let candidate = targets[0];
    for (const t of targets) {
      if (t.getBoundingClientRect().top <= line) candidate = t;
      else break;
    }
    const next = linkById.get(candidate.id);
    if (next === active) return;
    if (active) active.classList.remove('active');
    if (next) {
      next.classList.add('active');
      keepLinkVisibleInToc(next);
    }
    active = next;
  };

  let ticking = false;
  const schedule = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => { ticking = false; update(); });
  };
  window.addEventListener('scroll', schedule, { passive: true });
  window.addEventListener('resize', schedule);
  update();
})();
</script>
</body>
</html>
HTMLEOF

#!/bin/sh
set -e

if [ -z "$1" ]; then
	file=$(fd -e md --max-depth 1 . ~/Downloads ~/ -0 | xargs -0 stat -c '%Y	%n' | sort -rn | cut -f2- | fzf --no-sort)
	[ -z "$file" ] && exit 1
else
	file="$1"
fi

# Render to a stable cache path (not /tmp, which is wiped on reboot) so the
# file:// URL stays bookmarkable and reopening the same source overwrites in
# place. Self-contained HTML (inline CSS/JS, base64 font, mermaid via CDN over
# https) means no server is needed — file:// works.
abs=$(readlink -f "$file")
cachedir="${XDG_CACHE_HOME:-$HOME/.cache}/mdpreview"
mkdir -p "$cachedir"
out="$cachedir/$(basename "$abs" .md)-$(printf '%s' "$abs" | sha1sum | cut -c1-8).html"
md2html "$file" > "$out"
xdg-open "file://$out"

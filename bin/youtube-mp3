#!/usr/bin/env bash

youtube_id=""

arg=$1

if [[ $# -eq 0 ]]; then
	arg=$(zenity --entry --entry-text "$(pbpaste)")
	if [[ $? -ne 0 ]]; then
		echo "zenity exited with bad exit code"
		exit 1
	fi
fi

# accepts https://soundcloud.com/liminal-being/oslo2
if echo "$arg" | grep soundcloud.com; then
	url="$arg"
else
	# accepts https://www.youtube.com/watch?v=OLmqnG9b9fA&list=RDGMEM6ijAnFTG9nX1G-kbWBUCJA&index=2
	v_query_param=""
	if [[ "$arg" == *\?* ]]; then
		query="${arg#*\?}"
		IFS='&' read -ra _params <<< "$query"
		for _p in "${_params[@]}"; do
			if [[ "$_p" == v=* ]]; then
				v_query_param="${_p#v=}"
				break
			fi
		done
	fi

	if [ -n "$v_query_param" ]; then
		youtube_id="$v_query_param"
	else
		# accepts 'https://youtu.be/chh0H1BZeOA?si=Xz2BQjhkqGLPwQ3g'
		# accepts 'https://www.youtube.com/shorts/CJalATqPdpM'
		if [[ "$arg" == *://* ]]; then
			_rest="${arg#*://}"
			if [[ "$_rest" == */* ]]; then
				_path_with_query="${_rest#*/}"
				video_id="${_path_with_query%%\?*}"
			else
				video_id=""
			fi
		else
			video_id=""
		fi
		video_id="${video_id#shorts/}"

		if [ -n "$video_id" ]; then
			youtube_id="$video_id"
		else
			# accepts 'chh0H1BZeOA'
			youtube_id=$arg
		fi
	fi

	url="https://www.youtube.com/watch?v=$youtube_id" 
fi

yt-dlp --paths home:~/Dropbox/music --format ba --extract-audio --audio-format mp3 "$url"

#!/usr/bin/env bash
# pr — review a github PR with prr.
#
#   pr                      resume an in-progress review, or pick an open PR
#                           in the current repo via fzf
#   pr <owner>/<repo>/<num> review that specific PR (skips fzf)
#
# Resume-aware: prr tracks each review's state (NEW = fetched but untouched,
# REVIEWED = has unsubmitted comments/decision, SUBMITTED = sent). With no
# argument, any REVIEWED (in-progress) reviews are offered first so you can
# jump straight back in. For whichever PR is chosen, an existing unsubmitted
# review is resumed via `prr edit` instead of re-fetched with `prr get` (which
# would error on an unsubmitted review and could clobber drafts).
#
# The <owner>/<repo>/<num> form is what the prr:// scheme handler (bin/prr-open)
# invokes after deriving the id from a github PR url.
#
# Requires: gh (authed), prr (configured: ~/.config/prr/config.toml), fzf.

set -euo pipefail

# Status of a known review handle (empty if prr doesn't know it). `prr status`
# reads local review files only — no network. `|| true` so a non-zero exit
# (e.g. no reviews yet) doesn't trip `set -e`.
review_status() {
    { prr status -n 2>/dev/null || true; } | awk -v h="$1" '$1 == h { print $2; exit }'
}

target="${1:-}"

if [ -n "$target" ]; then
    # Explicit owner/repo/number. Validate strictly — this path is reachable
    # from a clickable prr:// link, so don't pass unsanitised input to prr/gh.
    case "$target" in
        [A-Za-z0-9._-]*/[A-Za-z0-9._-]*/[0-9]*) ;;
        *)
            echo "pr: expected <owner>/<repo>/<number>, got: $target" >&2
            exit 1
            ;;
    esac
    pr_id="$target"
else
    pr_id=""

    # Offer to resume in-progress (REVIEWED) reviews first — across all repos,
    # since you might have unfinished work elsewhere. ESC skips to a new review.
    reviewed=$({ prr status -n 2>/dev/null || true; } | awk '$2 == "REVIEWED" { print $1 }')
    if [ -n "$reviewed" ]; then
        pr_id=$(printf '%s\n' "$reviewed" \
          | fzf --prompt="resume> " \
                --header="in-progress reviews · ENTER resume · ESC to start a new one") || true
    fi

    # No resume picked → list open PRs in the current repo.
    if [ -z "$pr_id" ]; then
        repo=$(gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null) || {
            echo "pr: not a github repo (or gh not authed)" >&2
            exit 1
        }

        # number<TAB>title [@author] — tab keeps the number cleanly separable.
        prs=$(gh pr list --state open --limit 200 \
            --json number,title,author \
            --jq '.[] | "\(.number)\t\(.title)  [@\(.author.login)]"') || {
            echo "pr: failed to list PRs for $repo" >&2
            exit 1
        }

        [ -n "$prs" ] || {
            echo "pr: no open PRs in $repo" >&2
            exit 0
        }

        # Map each PR number in this repo to its prr review state, so the
        # picker can flag which PRs already have a review going.
        declare -A review_state=()
        while read -r handle status _; do
            review_state["${handle##*/}"]="$status"
        done < <({ prr status -n 2>/dev/null || true; } | awk -v r="$repo/" 'index($1, r) == 1')

        # Annotate: <number>  [<label>]  <title> [@author]. Number stays first
        # so the awk extraction below is unaffected.
        annotated=""
        while IFS=$'\t' read -r num rest; do
            case "${review_state[$num]:-}" in
                REVIEWED)  label="[in-progress]" ;;
                NEW)       label="[fetched]    " ;;
                SUBMITTED) label="[submitted]  " ;;
                *)         label="             " ;;
            esac
            annotated+=$(printf '%-5s %s %s' "$num" "$label" "$rest")$'\n'
        done <<< "$prs"

        selected=$(printf '%s' "$annotated" \
          | fzf --prompt="PR> " \
                --header="open PRs in $repo · [in-progress]=unsubmitted review · enter: review") || exit 0

        num=$(printf '%s' "$selected" | awk '{print $1}')
        [ -n "$num" ] || exit 0
        pr_id="$repo/$num"
    fi
fi

# Print the PR url to stderr up front. ghostty makes it clickable, and being
# before the editor means it survives any exit path (:wq, :cq, C-z + kill, …).
printf 'PR: https://github.com/%s/pull/%s\n' "${pr_id%/*}" "${pr_id##*/}" >&2

# Resume an existing unsubmitted review (NEW/REVIEWED) rather than re-fetching.
case "$(review_status "$pr_id")" in
    NEW|REVIEWED)
        prr edit "$pr_id"
        ;;
    *)
        prr get "$pr_id"
        prr edit "$pr_id"
        ;;
esac

# Editor closed cleanly (set -e would have bailed on failure). Offer to
# submit. Enter / Y submits via prr (the @prr approve|reject|comment
# directive in the file picks the review type; default is comment-only).
# Any other key skips submit and leaves the .prr file as a draft.
read -rp "Submit review for $pr_id? [Y/n] " ans
case "$ans" in
    ""|y|Y|yes|YES)
        prr submit "$pr_id"
        ;;
    *)
        echo "skipped; draft kept at \$workdir/$pr_id.prr"
        ;;
esac

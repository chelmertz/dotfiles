#!/usr/bin/env python3
"""Generate daily integration files for the Obsidian vault.

Writes integrations/YYYY-MM-DD.md for today and the last 7 completed days.
A "day" runs 04:00 local → 04:00 next day.
Today is regenerated on every run; older days are written once unless missing.

Uses 2 GitHub API calls per run (batch fetch, then group by date).

Intended to run on a timer (every 15min via systemd).
"""

import json
import re
import subprocess
from collections import defaultdict
from datetime import datetime, timedelta, time, date as Date
from pathlib import Path

VAULT = Path.home() / "Dropbox" / "notes"
CODE_DIR = Path.home() / "code"
DIARY_LOG = Path.home() / ".claude-diary.jsonl"
CLAUDE_PROJECTS_DIR = Path.home() / ".claude" / "projects"
DAY_BOUNDARY = time(4, 0)
LOOKBACK_DAYS = 7
MTIME_CUSHION_DAYS = 2
WORK_ORG = "matchiapp"
GIT_AUTHOR_EMAIL = "helmertz@gmail.com"
PR_LINK_RE = re.compile(
    r'\[Page not found[^\]]*\]\((https://github\.com/[^/]+/[^/]+/pull/\d+)(?:[^)]*)\)'
)
CLAUDE_BULLET_RE = re.compile(
    r'^- (\d{2}:\d{2})\s{2}(.+?)(?:\s{2}·\s+(\S+)(?:\s+\(([^)]+)\))?)?$'
)


def logical_today():
    now = datetime.now()
    if now.time() < DAY_BOUNDARY:
        return (now - timedelta(days=1)).date()
    return now.date()


def gh_json(args):
    result = subprocess.run(
        ["gh"] + args,
        capture_output=True, text=True, timeout=30
    )
    if result.returncode != 0:
        return []
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError:
        return []


def pr_date(pr):
    """Extract the local date from closedAt, shifted by DAY_BOUNDARY."""
    ts = pr.get("closedAt", "")
    if not ts:
        return None
    dt = datetime.fromisoformat(ts.replace("Z", "+00:00")).astimezone()
    if dt.time() < DAY_BOUNDARY:
        return (dt - timedelta(days=1)).date()
    return dt.date()


def fetch_all_prs(start_date, end_date):
    """Batch fetch authored + reviewed PRs for entire date range. 2 API calls."""
    authored = gh_json([
        "search", "prs",
        "--author=@me", "--merged",
        f"--merged-at={start_date}..{end_date}",
        "--json", "title,repository,url,closedAt",
        "--limit", "100",
    ])
    reviewed = gh_json([
        "search", "prs",
        "--review-requested=@me", "--state=closed",
        f"--closed={start_date}..{end_date}",
        "--json", "title,repository,url,closedAt,author",
        "--limit", "100",
    ])
    return authored, reviewed


def group_by_date(prs):
    by_date = defaultdict(list)
    for pr in prs:
        d = pr_date(pr)
        if d:
            by_date[d].append(pr)
    return by_date


def is_work(pr):
    return pr["repository"]["nameWithOwner"].startswith(WORK_ORG + "/")


# ── Git repos ─────────────────────────────────────────────────────

def find_git_repos():
    """Find all git repos under CODE_DIR."""
    result = subprocess.run(
        ["find", str(CODE_DIR), "-maxdepth", "5",
         "-name", "HEAD", "-path", "*/.git/HEAD"],
        capture_output=True, text=True, timeout=10
    )
    repos = []
    for line in result.stdout.strip().split("\n"):
        if line:
            repos.append(Path(line).parent.parent)
    return repos


def git_commit_count_for_day(repo, date):
    """Count commits for a repo on a given logical day (04:00→04:00)."""
    start = f"{date}T04:00"
    end = f"{date + timedelta(days=1)}T04:00"
    result = subprocess.run(
        ["git", "-C", str(repo), "rev-list", "--count",
         f"--after={start}", f"--before={end}",
         f"--author={GIT_AUTHOR_EMAIL}",
         "--no-merges", "HEAD"],
        capture_output=True, text=True, timeout=5
    )
    if result.returncode != 0:
        return 0
    return int(result.stdout.strip() or 0)


def repo_github_url(repo):
    """Try to get GitHub URL from git remote."""
    result = subprocess.run(
        ["git", "-C", str(repo), "remote", "get-url", "origin"],
        capture_output=True, text=True, timeout=5
    )
    url = result.stdout.strip()
    if "github.com" in url:
        # Normalize ssh/https to https
        url = url.replace("git@github.com:", "https://github.com/")
        url = url.removesuffix(".git")
        return url
    return None


def fetch_git_activity(dates):
    """Returns {date: [(repo_name, commit_count, github_url)]} for all dates."""
    repos = find_git_repos()
    by_date = defaultdict(list)
    # Cache github URLs
    url_cache = {}
    for repo in repos:
        for d in dates:
            count = git_commit_count_for_day(repo, d)
            if count > 0:
                if repo not in url_cache:
                    url_cache[repo] = repo_github_url(repo)
                by_date[d].append((repo.name, count, url_cache[repo]))
    for d in by_date:
        by_date[d].sort(key=lambda x: x[0])
    return by_date


# ── Claude sessions ────────────────────────────────────────────────

def load_diary_metadata():
    """Returns {session_id: diary_entry} from ~/.claude-diary.jsonl."""
    meta = {}
    if not DIARY_LOG.exists():
        return meta
    try:
        with open(DIARY_LOG) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                except json.JSONDecodeError:
                    continue
                sid = entry.get("session_id")
                if sid:
                    meta[sid] = entry
    except OSError:
        pass
    return meta


def logical_day_of(dt):
    if dt.time() < DAY_BOUNDARY:
        return (dt - timedelta(days=1)).date()
    return dt.date()


def scan_session_jsonl(path):
    """Return ({day: earliest_dt_that_day}, fallback_cwd, fallback_first_user_text)
    for a session JSONL, or None if it's a 'claude -p' sdk-cli run (noise from
    the diary hook itself).
    """
    day_to_first_dt = {}
    fallback_cwd = None
    fallback_first_text = None
    checked_entrypoint = False
    try:
        with open(path) as f:
            for line in f:
                if '"type":"user"' not in line:
                    continue
                try:
                    msg = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if not checked_entrypoint:
                    checked_entrypoint = True
                    if msg.get("entrypoint") == "sdk-cli":
                        return None
                if msg.get("type") != "user" or msg.get("isSidechain"):
                    continue
                ts = msg.get("timestamp")
                if not ts:
                    continue
                try:
                    dt = datetime.fromisoformat(ts.replace("Z", "+00:00")).astimezone()
                except ValueError:
                    continue
                d = logical_day_of(dt)
                prev = day_to_first_dt.get(d)
                if prev is None or dt < prev:
                    day_to_first_dt[d] = dt
                if fallback_cwd is None:
                    fallback_cwd = msg.get("cwd")
                if fallback_first_text is None:
                    m = msg.get("message")
                    if isinstance(m, dict):
                        content = m.get("content")
                        if isinstance(content, str):
                            fallback_first_text = content
                        elif isinstance(content, list):
                            for c in content:
                                if isinstance(c, dict) and c.get("type") == "text":
                                    fallback_first_text = c.get("text", "")
                                    break
    except OSError:
        return None
    return day_to_first_dt, fallback_cwd, fallback_first_text


def fetch_claude_sessions(dates):
    """Returns {date: [session_row]} covering every (session, logical_day) where
    the user prompted that day. Rows include `is_new` = True iff that day is the
    session's earliest active day in its JSONL.

    Source of activity: ~/.claude/projects/*/*.jsonl (Claude's own session logs).
    mtime filter keeps cost low (only opens recently touched sessions).
    Source of summary/branch/cwd: ~/.claude-diary.jsonl (per-session metadata
    captured by claude-diary-hook on first prompt).
    """
    by_date = defaultdict(list)
    if not dates or not CLAUDE_PROJECTS_DIR.exists():
        return by_date

    meta = load_diary_metadata()
    dates_set = set(dates)

    cutoff_date = min(dates) - timedelta(days=MTIME_CUSHION_DAYS)
    cutoff_ts = datetime.combine(cutoff_date, time(0, 0)).timestamp()

    for proj_dir in CLAUDE_PROJECTS_DIR.iterdir():
        if not proj_dir.is_dir():
            continue
        for jsonl in proj_dir.glob("*.jsonl"):
            try:
                if jsonl.stat().st_mtime < cutoff_ts:
                    continue
            except OSError:
                continue
            result = scan_session_jsonl(jsonl)
            if result is None:
                continue
            day_to_first_dt, fb_cwd, fb_text = result
            if not day_to_first_dt:
                continue
            sid = jsonl.stem
            earliest_day = min(day_to_first_dt)
            m = meta.get(sid, {})
            for d, dt in day_to_first_dt.items():
                if d not in dates_set:
                    continue
                by_date[d].append({
                    "session_id": sid,
                    "timestamp": dt.isoformat(),
                    "is_new": (d == earliest_day),
                    "summary": m.get("summary", ""),
                    "prompt": m.get("prompt") or (fb_text or ""),
                    "cwd": m.get("cwd") or (fb_cwd or ""),
                    "branch": m.get("branch", ""),
                })

    for d in by_date:
        by_date[d].sort(key=lambda e: e.get("timestamp", ""))
    return by_date


def shorten_path(p):
    home = str(Path.home())
    if p.startswith(home):
        return "~" + p[len(home):]
    return p


def md_link(text, url):
    """Markdown link with `[`, `]`, and backslash escaped in the text."""
    text = (text
        .replace("\\", "\\\\")
        .replace("[", "\\[")
        .replace("]", "\\]"))
    return f"[{text}]({url})"


def md_cell(text):
    """Make a string safe to drop into a GFM table cell."""
    return text.replace("|", "\\|").replace("\n", " ")


def fmt_urls(prs):
    lines = []
    for pr in prs:
        lines.append(f"    - {pr['url']}")
    return "\n".join(lines) if lines else "    []"


def generate_day(authored, reviewed, git_repos, claude_sessions=None):
    claude_sessions = claude_sessions or []
    if not authored and not reviewed and not git_repos and not claude_sessions:
        return None

    work_authored = [p for p in authored if is_work(p)]
    work_reviewed = [p for p in reviewed if is_work(p)]
    priv_authored = [p for p in authored if not is_work(p)]
    priv_reviewed = [p for p in reviewed if not is_work(p)]

    pr_repos = sorted(set(
        pr["repository"]["nameWithOwner"].split("/")[-1]
        for pr in authored + reviewed
    ))
    git_repo_names = sorted(set(name for name, _, _ in git_repos))
    all_repos = sorted(set(pr_repos + git_repo_names))
    total_commits = sum(count for _, count, _ in git_repos)

    frontmatter = f"""---
prs_authored: {len(authored)}
prs_reviewed: {len(reviewed)}
commits: {total_commits}
claude_sessions: {len(claude_sessions)}
repos: [{', '.join(all_repos)}]
git_repos: [{', '.join(git_repo_names)}]
work:
  org: {WORK_ORG}
  prs_authored: {len(work_authored)}
  prs_reviewed: {len(work_reviewed)}
  pr_urls:
{fmt_urls(work_authored + work_reviewed)}
private:
  prs_authored: {len(priv_authored)}
  prs_reviewed: {len(priv_reviewed)}
  pr_urls:
{fmt_urls(priv_authored + priv_reviewed)}
---"""

    sections = []

    # ── Pull requests ──────────────────────────────────────────
    if authored or reviewed:
        total_prs = len(authored) + len(reviewed)
        lines = [f"## Pull requests ({total_prs})"]
        lines.append("")
        for pr in authored:
            repo = pr["repository"]["nameWithOwner"]
            repo_short = repo.split("/")[-1]
            repo_url = f"https://github.com/{repo}"
            lines.append(
                f"- \\* {md_link(pr['title'], pr['url'])} · "
                f"{md_link(repo_short, repo_url)}"
            )
        for pr in reviewed:
            repo = pr["repository"]["nameWithOwner"]
            repo_short = repo.split("/")[-1]
            repo_url = f"https://github.com/{repo}"
            author = pr.get("author", {}).get("login", "?")
            lines.append(
                f"- \\> {md_link(pr['title'], pr['url'])} · "
                f"{md_link(repo_short, repo_url)} · {author}"
            )
        sections.append("\n".join(lines))

    # ── Git repos touched ─────────────────────────────────────
    if git_repos:
        lines = [f"## Git repos touched ({len(git_repos)})"]
        lines.append("")
        repo_parts = []
        for name, count, url in git_repos:
            if url:
                repo_parts.append(f"{md_link(name, url)} ({count})")
            else:
                repo_parts.append(f"{name} ({count})")
        lines.append(" · ".join(repo_parts))
        sections.append("\n".join(lines))

    # ── Claude sessions ──────────────────────────────────────
    if claude_sessions:
        lines = [f"## Claude sessions ({len(claude_sessions)})"]
        lines.append("")
        lines.append("| Time | Repo | Title |")
        lines.append("|------|------|-------|")
        for s in claude_sessions:
            ts = s.get("timestamp", "")
            try:
                t = datetime.fromisoformat(ts).strftime("%H:%M")
            except ValueError:
                t = "?"
            summary = s.get("summary", "")
            if not summary or len(summary) > 80:
                prompt = s.get("prompt", "")
                summary = prompt.split("\n")[0][:60] if prompt else "?"
            if len(summary) > 60:
                summary = summary[:59] + "…"
            folder = shorten_path(s.get("cwd", ""))
            repo = folder.split("/")[-1] if folder else "?"
            branch = s.get("branch", "")
            if branch and branch != "master" and branch != "main":
                repo += f" ({branch})"
            sid = s.get("session_id", "")
            marker = "🆕 " if s.get("is_new") else ""
            if sid:
                title_cell = md_cell(marker + md_link(summary, f"claude-resume://{sid}"))
            else:
                title_cell = md_cell(marker + summary)
            lines.append(f"| {t} | {md_cell(repo)} | {title_cell} |")
        sections.append("\n".join(lines))

    return frontmatter + "\n\n" + "\n\n".join(sections) + "\n"


def ensure_daily_note(d):
    """Create journal/YYYY-MM-DD.md from the vault template if it doesn't exist."""
    note = VAULT / "journal" / f"{d}.md"
    if note.exists():
        return
    template = VAULT / "templates" / "daily.md"
    if not template.exists():
        return
    content = template.read_text()
    # Replace Templater date expressions with the actual date.
    # Handles <% tp.date.now("YYYY-MM-DD") %> and similar formats.
    def replace_tp_date(m):
        fmt = m.group(1)
        py_fmt = fmt.replace("YYYY", "%Y").replace("MM", "%m").replace("DD", "%d")
        return d.strftime(py_fmt)
    content = re.sub(r'<%\s*tp\.date\.now\("([^"]+)"\)\s*%>', replace_tp_date, content)
    note.parent.mkdir(parents=True, exist_ok=True)
    note.write_text(content)
    print(f"  {d}: created daily note")


def fix_broken_github_pr_links():
    """Scan vault for 'Page not found' GitHub PR links, replace with actual titles."""
    file_texts = {}
    all_urls = set()
    for md in VAULT.rglob("*.md"):
        if ".obsidian" in md.parts or md.parent.name == "integrations":
            continue
        text = md.read_text()
        urls = PR_LINK_RE.findall(text)
        if urls:
            file_texts[md] = text
            all_urls.update(urls)

    if not all_urls:
        return

    titles = {}
    for url in all_urls:
        result = gh_json(["pr", "view", url, "--json", "title"])
        if isinstance(result, dict) and "title" in result:
            titles[url] = result["title"]

    if not titles:
        return

    fixed = 0
    for md, text in file_texts.items():
        new_text = text
        for url, title in titles.items():
            safe = title.replace("[", "\\[").replace("]", "\\]")
            new_text = re.sub(
                r'\[Page not found[^\]]*\]\(' + re.escape(url) + r'(?:[^)]*)\)',
                f'[{safe}]({url})',
                new_text,
            )
        if new_text != text:
            md.write_text(new_text)
            fixed += 1
    if fixed:
        print(f"  fixed broken PR links in {fixed} file(s)")


def migrate_claude_sessions_to_table(outdir):
    """Convert old bullet-list Claude sessions to table format in existing files."""
    for md in sorted(outdir.glob("*.md")):
        text = md.read_text()
        lines = text.split("\n")

        # Find Claude sessions section header
        start = None
        for i, line in enumerate(lines):
            if line.startswith("## Claude sessions"):
                start = i
                break
        if start is None:
            continue

        # Already migrated?
        if any(lines[j].startswith("| Time") for j in range(start + 1, min(start + 4, len(lines)))):
            continue

        # Find end of section (next ## or end of content)
        end = len(lines)
        for i in range(start + 1, len(lines)):
            if lines[i].startswith("## "):
                end = i
                break

        # Parse bullet lines
        bullets = []
        for i in range(start + 1, end):
            m = CLAUDE_BULLET_RE.match(lines[i])
            if m:
                bullets.append(m.groups())
        if not bullets:
            continue

        # Build table
        table_lines = [lines[start], "", "| Time | Repo | Title |", "|------|------|-------|"]
        for time_str, summary, folder, branch in bullets:
            repo = folder.split("/")[-1] if folder else "?"
            if branch:
                repo += f" ({branch})"
            summary = summary.replace("|", "\\|")
            table_lines.append(f"| {time_str} | {repo} | {summary} |")
        table_lines.append("")

        new_lines = lines[:start] + table_lines + lines[end:]
        new_text = "\n".join(new_lines)
        if new_text != text:
            md.write_text(new_text)
            print(f"  {md.name}: migrated claude sessions to table")


def main():
    today = logical_today()
    outdir = VAULT / "integrations"
    outdir.mkdir(parents=True, exist_ok=True)

    dates = [today - timedelta(days=i) for i in range(0, LOOKBACK_DAYS + 1)]

    migrate_claude_sessions_to_table(outdir)

    # Always regenerate every lookback day. A session resumed today may add a
    # row to today's note AND retroactively mark its original-day row, so we
    # can't skip "already exists" days.
    needed = list(dates)
    start_date = min(needed)
    end_date = max(needed)

    authored_all, reviewed_all = fetch_all_prs(start_date, end_date)
    authored_by_date = group_by_date(authored_all)
    reviewed_by_date = group_by_date(reviewed_all)
    git_by_date = fetch_git_activity(needed)
    claude_by_date = fetch_claude_sessions(set(needed))

    for d in needed:
        path = outdir / f"{d}.md"
        content = generate_day(
            authored_by_date.get(d, []),
            reviewed_by_date.get(d, []),
            git_by_date.get(d, []),
            claude_by_date.get(d, []),
        )
        if not content:
            print(f"  {d}: no data")
            continue
        existing = path.read_text() if path.exists() else None
        if content == existing:
            continue
        path.write_text(content)
        ensure_daily_note(d)
        print(f"  {d}: updated")

    fix_broken_github_pr_links()


if __name__ == "__main__":
    main()

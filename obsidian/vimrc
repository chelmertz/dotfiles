" dagbok — Obsidian vim config
" Loaded by obsidian-vimrc-support plugin

" ── Surround support (built into the plugin) ─────
exmap surround_wiki surround [[ ]]
exmap surround_double_quotes surround " "
exmap surround_single_quotes surround ' '
exmap surround_backticks surround ` `
exmap surround_brackets surround ( )
exmap surround_square_brackets surround [ ]
exmap surround_curly_brackets surround { }
exmap surround_bold surround ** **
exmap surround_italic surround * *

" vim-surround-style: visual select then S{char}
nunmap S
vunmap S

map S" :surround_double_quotes<CR>
map S' :surround_single_quotes<CR>
map S` :surround_backticks<CR>
map Sb :surround_brackets<CR>
map S( :surround_brackets<CR>
map S) :surround_brackets<CR>
map S[ :surround_square_brackets<CR>
map S] :surround_square_brackets<CR>
map S{ :surround_curly_brackets<CR>
map S} :surround_curly_brackets<CR>
map S* :surround_italic<CR>
map SB :surround_bold<CR>
map Sw :surround_wiki<CR>

" ── Navigation ────────────────────────────────────
nmap j gj
nmap k gk
vmap j gj
vmap k gk
nmap H ^
nmap L $

" ── Leader (,) ────────────────────────────────────
" ── Obsidian commands ──────────────────────────────
" Ctrl+Shift+D = daily note
" Ctrl+Shift+T = bookmarks (dash_tasks)
" Ctrl+Shift+F = search
" Ctrl+P = command palette (built-in)
